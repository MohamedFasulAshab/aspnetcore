@using Microsoft.AspNetCore.Components.Web
@namespace Microsoft.AspNetCore.Components.QuickGrid

<div class="paginator">
    @if (State.TotalItemCount.HasValue)
    {
        <div class="summary">
            @if (SummaryTemplate is not null)
            {
                @SummaryTemplate
            }
            else
            {
                <text><strong>@State.TotalItemCount</strong>  @Localizer["Items"]</text>
            }
        </div>
        <nav role="navigation">
            @if (QuickGridFeatureFlags.EnableUrlBasedQuickGridNavigationAndSorting)
            {
                <a class="go-first"
                   href="@(CanGoBack ? GetPageUrl(0) : null)"
                   title=" @Localizer["GoToFirstPage"]"
                   aria-label=" @Localizer["GoToFirstPage"]"
                   aria-disabled="@(!CanGoBack ? "true" : "false")">«</a>

                <a class="go-previous"
                   href="@(CanGoBack ? GetPageUrl(State.CurrentPageIndex - 1) : null)"
                   title=" @Localizer["GoToPreviousPage"]"
                   aria-label=" @Localizer["GoToPreviousPage"]"
                   aria-disabled="@(!CanGoBack ? "true" : "false")">‹</a>

                <div class="pagination-text">
                     @PaginationPageStatus
                </div>

                <a class="go-next"
                   href="@(CanGoForwards ? GetPageUrl(State.CurrentPageIndex + 1) : null)"
                   title=" @Localizer["GoToNextPage"]"
                   aria-label=" @Localizer["GoToNextPage"]"
                   aria-disabled="@(!CanGoForwards ? "true" : "false")">›</a>

                <a class="go-last"
                   href="@(CanGoForwards ? GetPageUrl(State.LastPageIndex.GetValueOrDefault(0)) : null)"
                   title=" @Localizer["GoToLastPage"]"
                   aria-label=" @Localizer["GoToLastPage"]"
                   aria-disabled="@(!CanGoForwards ? "true" : "false")">»</a>
            }
            else
            {
                <button class="go-first"
                        type="button"
                        @onclick="GoFirstAsync"
                        disabled="@(!CanGoBack)"
                        title=" @Localizer["GoToFirstPage"]"
                        aria-label=" @Localizer["GoToFirstPage"]"></button>

                <button class="go-previous"
                        type="button"
                        @onclick="GoPreviousAsync"
                        disabled="@(!CanGoBack)"
                        title=" @Localizer["GoToPreviousPage"]"
                        aria-label=" @Localizer["GoToPreviousPage"]"></button>

                <div class="pagination-text">
                    @PaginationPageStatus
                </div>

                <button class="go-next"
                        type="button"
                        @onclick="GoNextAsync"
                        disabled="@(!CanGoForwards)"
                        title=" @Localizer["GoToNextPage"]"
                        aria-label=" @Localizer["GoToNextPage"]"></button>

                <button class="go-last"
                        type="button"
                        @onclick="GoLastAsync"
                        disabled="@(!CanGoForwards)"
                        title=" @Localizer["GoToLastPage"]"
                        aria-label=" @Localizer["GoToLastPage"]"></button>
            }
        </nav>
    }
</div>