@using Microsoft.AspNetCore.Components.Web
@namespace Microsoft.AspNetCore.Components.QuickGrid

<div class="paginator">
    @if (State.TotalItemCount.HasValue)
    {
        <div class="summary">
            @if (SummaryTemplate is not null)
            {
                @SummaryTemplate
            }
            else
            {
                <text><strong>@State.TotalItemCount</strong> @(State.TotalItemCount == 1 ? ItemSingularText : ItemPluralText)</text>
            }
        </div>
        <nav role="navigation">
            @if (QuickGridFeatureFlags.EnableUrlBasedQuickGridNavigationAndSorting)
            {
                <a class="go-first" href="@(CanGoBack ? GetPageUrl(0) : null)" title="@FirstPageTitle" aria-label="@FirstPageAriaLabel" aria-disabled="@(!CanGoBack ? "true" : "false")">«</a>
                <a class="go-previous" href="@(CanGoBack ? GetPageUrl(State.CurrentPageIndex - 1) : null)" title="@PreviousPageTitle" aria-label="@PreviousPageAriaLabel" aria-disabled="@(!CanGoBack ? "true" : "false")">‹</a>
                <div class="pagination-text">
                    @String.Format(PageLabelFormat, State.CurrentPageIndex + 1, State.LastPageIndex + 1)
                </div>
                <a class="go-next" href="@(CanGoForwards ? GetPageUrl(State.CurrentPageIndex + 1) : null)" title="@NextPageTitle" aria-label="@NextPageAriaLabel" aria-disabled="@(!CanGoForwards ? "true" : "false")">›</a>
                <a class="go-last" href="@(CanGoForwards ? GetPageUrl(State.LastPageIndex.GetValueOrDefault(0)) : null)" title="@LastPageTitle" aria-label="@LastPageAriaLabel" aria-disabled="@(!CanGoForwards ? "true" : "false")">»</a>
            }
            else
            {
                <button class="go-first" type="button" @onclick="GoFirstAsync" disabled="@(!CanGoBack)" title="@FirstPageTitle" aria-label="@FirstPageAriaLabel"></button>
                <button class="go-previous" type="button" @onclick="GoPreviousAsync" disabled="@(!CanGoBack)" title="@PreviousPageTitle" aria-label="@PreviousPageAriaLabel"></button>
                <div class="pagination-text">
                    @String.Format(PageLabelFormat, State.CurrentPageIndex + 1, State.LastPageIndex + 1)
                </div>
                <button class="go-next" type="button" @onclick="GoNextAsync" disabled="@(!CanGoForwards)" title="@NextPageTitle" aria-label="@NextPageAriaLabel"></button>
                <button class="go-last" type="button" @onclick="GoLastAsync" disabled="@(!CanGoForwards)" title="@LastPageTitle" aria-label="@LastPageAriaLabel"></button>
            }
        </nav>
    }
</div>
