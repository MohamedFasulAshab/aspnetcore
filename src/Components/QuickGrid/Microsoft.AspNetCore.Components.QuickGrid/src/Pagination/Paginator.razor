@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@namespace Microsoft.AspNetCore.Components.QuickGrid

<div class="paginator">
    @if (State.TotalItemCount.HasValue)
    {
        <div class="summary">
            @if (SummaryTemplate is not null)
            {
                @SummaryTemplate
            }
            else
            {
                <text><strong>@State.TotalItemCount</strong> @L("Paginator_ItemsSummary", State.TotalItemCount.Value)</text>
            }
        </div>
        <nav role="navigation">
            @if (QuickGridFeatureFlags.EnableUrlBasedQuickGridNavigationAndSorting)
            {
                <a class="go-first" href="@(CanGoBack ? GetPageUrl(0) : null)" title="@L("Paginator_GoToFirstPage")" aria-label="@L("Paginator_GoToFirstPage")" aria-disabled="@(!CanGoBack ? "true" : "false")">«</a>
                <a class="go-previous" href="@(CanGoBack ? GetPageUrl(State.CurrentPageIndex - 1) : null)" title="@L("Paginator_GoToPreviousPage")" aria-label="@L("Paginator_GoToPreviousPage")" aria-disabled="@(!CanGoBack ? "true" : "false")">‹</a>
                <div class="pagination-text">
                    @L("Paginator_Page") <strong>@(State.CurrentPageIndex + 1)</strong>
                    @L("Paginator_Of") <strong>@(State.LastPageIndex + 1)</strong>
                </div>
                <a class="go-next" href="@(CanGoForwards ? GetPageUrl(State.CurrentPageIndex + 1) : null)" title="@L("Paginator_GoToNextPage")" aria-label="@L("Paginator_GoToNextPage")" aria-disabled="@(!CanGoForwards ? "true" : "false")">›</a>
                <a class="go-last" href="@(CanGoForwards ? GetPageUrl(State.LastPageIndex.GetValueOrDefault(0)) : null)" title="@L("Paginator_GoToLastPage")" aria-label="@L("Paginator_GoToLastPage")" aria-disabled="@(!CanGoForwards ? "true" : "false")">»</a>
            }
            else
            {
                <button class="go-first" type="button" @onclick="GoFirstAsync" disabled="@(!CanGoBack)" title="@L("Paginator_GoToFirstPage")" aria-label="@L("Paginator_GoToFirstPage")"></button>
                <button class="go-previous" type="button" @onclick="GoPreviousAsync" disabled="@(!CanGoBack)" title="@L("Paginator_GoToPreviousPage")" aria-label="@L("Paginator_GoToPreviousPage")"></button>
                <div class="pagination-text">
                    @L("Paginator_Page") <strong>@(State.CurrentPageIndex + 1)</strong>
                    @L("Paginator_Of") <strong>@(State.LastPageIndex + 1)</strong>
                </div>
                <button class="go-next" type="button" @onclick="GoNextAsync" disabled="@(!CanGoForwards)" title="@L("Paginator_GoToNextPage")" aria-label="@L("Paginator_GoToNextPage")"></button>
                <button class="go-last" type="button" @onclick="GoLastAsync" disabled="@(!CanGoForwards)" title="@L("Paginator_GoToLastPage")" aria-label="@L("Paginator_GoToLastPage")"></button>
            }
        </nav>
    }
</div>
