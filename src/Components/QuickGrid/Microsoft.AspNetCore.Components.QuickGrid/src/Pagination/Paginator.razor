@using Microsoft.AspNetCore.Components.Web
@namespace Microsoft.AspNetCore.Components.QuickGrid

<div class="paginator">
    @if (State.TotalItemCount.HasValue)
    {
        <div class="summary">
            @if (SummaryTemplate is not null)
            {
                @SummaryTemplate
            }
            else
            {
                <text>@ResolvedSummaryText</text>
            }
        </div>
        <nav role="navigation">
            @if (QuickGridFeatureFlags.EnableUrlBasedQuickGridNavigationAndSorting)
            {
                <a class="go-first" href="@(CanGoBack ? GetPageUrl(0) : null)" title="@ResolvedFirstPageTitle" aria-label="@ResolvedFirstPageAriaLabel" aria-disabled="@(!CanGoBack ? "true" : "false")">�</a>
                <a class="go-previous" href="@(CanGoBack ? GetPageUrl(State.CurrentPageIndex - 1) : null)" title="@ResolvedPreviousPageTitle" aria-label="@ResolvedPreviousPageAriaLabel" aria-disabled="@(!CanGoBack ? "true" : "false")">�</a>
                <div class="pagination-text">
                    @ResolvedPageLabelText
                </div>
                <a class="go-next" href="@(CanGoForwards ? GetPageUrl(State.CurrentPageIndex + 1) : null)" title="@ResolvedNextPageTitle" aria-label="@ResolvedNextPageAriaLabel" aria-disabled="@(!CanGoForwards ? "true" : "false")">�</a>
                <a class="go-last" href="@(CanGoForwards ? GetPageUrl(State.LastPageIndex.GetValueOrDefault(0)) : null)" title="@ResolvedLastPageTitle" aria-label="@ResolvedLastPageAriaLabel" aria-disabled="@(!CanGoForwards ? "true" : "false")">�</a>
            }
            else
            {
                <button class="go-first" type="button" @onclick="GoFirstAsync" disabled="@(!CanGoBack)" title="@ResolvedFirstPageTitle" aria-label="@ResolvedFirstPageAriaLabel"></button>
                <button class="go-previous" type="button" @onclick="GoPreviousAsync" disabled="@(!CanGoBack)" title="@ResolvedPreviousPageTitle" aria-label="@ResolvedPreviousPageAriaLabel"></button>
                <div class="pagination-text">
                    @ResolvedPageLabelText
                </div>
                <button class="go-next" type="button" @onclick="GoNextAsync" disabled="@(!CanGoForwards)" title="@ResolvedNextPageTitle" aria-label="@ResolvedNextPageAriaLabel"></button>
                <button class="go-last" type="button" @onclick="GoLastAsync" disabled="@(!CanGoForwards)" title="@ResolvedLastPageTitle" aria-label="@ResolvedLastPageAriaLabel"></button>
            }
        </nav>
    }
</div>